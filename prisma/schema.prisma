// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  expenses  Expense[]
  incomes   Income[]
  budgets   Budget[]
  createdAt DateTime  @default(now())
}

model Expense {
  id              String   @id @default(uuid())
  amount          Float
  description     String
  categoryType    String // need or want
  subcategory     String
  transactionDate DateTime
  source          String // chat or csv
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Income {
  id              String   @id @default(uuid())
  amount          Float
  description     String?
  transactionDate DateTime @default(now())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Budget {
  id          String   @id @default(uuid())
  month       Int
  year        Int
  totalAmount Float
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([userId, month, year])
}

model CategoryRule {
  id          String @id @default(uuid())
  keyword     String @unique
  subcategory String
  type        String // need or want
}
